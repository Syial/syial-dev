---
const { id, number, title } = Astro.props;
---

<section id={id} class="grid grid-cols-1 md:grid-cols-[140px_1fr] gap-x-8 gap-y-6 py-16 border-b border-line">
  {Astro.slots.has("heading") && (
    <>
      <div class="hidden md:block"></div>
      <div><slot name="heading" /></div>
    </>
  )}
  <div class="text-xs tracking-widest uppercase text-muted pt-1">
    {number} — {title}
  </div>
  <div>
    <slot />
  </div>
</section>